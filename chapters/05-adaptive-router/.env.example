# 至少填写一个真实 Key；双模型路由需要两边都配置。
DEEPSEEK_API_KEY=把你的_DeepSeek_API_Key_填在这里
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

ZAI_API_KEY=把你的_ZAI_API_Key_填在这里
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZAI_MODEL=glm-5.2

DEFAULT_PROVIDER=deepseek
MAX_TOKENS=512
MEMORY_PATH=data/conversation.json
ROUTER_PATH=data/router_state.json

# balanced / fast / quality
ROUTER_POLICY=balanced
