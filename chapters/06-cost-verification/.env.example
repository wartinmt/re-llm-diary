# 至少填写一个真实 API Key。不要提交 .env。
DEEPSEEK_API_KEY=把你的_DeepSeek_API_Key_填在这里
ZAI_API_KEY=把你的_ZAI_API_Key_填在这里

# 模型与端点。运行前以平台最新官方文档为准。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZAI_MODEL=glm-5.2

# 人民币 / 百万 Token。资料核对日期：2026-07-17。
# 价格会变化；真正运行前请去官方价格页复核并修改本文件的副本 .env。
DEEPSEEK_PRICE_CACHE_HIT_CNY=0.02
DEEPSEEK_PRICE_CACHE_MISS_CNY=1
DEEPSEEK_PRICE_OUTPUT_CNY=2
ZAI_PRICE_CACHE_HIT_CNY=2
ZAI_PRICE_CACHE_MISS_CNY=8
ZAI_PRICE_OUTPUT_CNY=28

# 0 到 1 的本地速度先验；真实运行后会逐渐被平均耗时修正。
DEEPSEEK_SPEED_HINT=0.85
ZAI_SPEED_HINT=0.72

DEFAULT_PROVIDER=deepseek
ROUTER_MODE=auto
ROUTER_POLICY=balanced
VERIFY_MODE=auto
AUTO_FALLBACK=false
TURN_BUDGET_CNY=0.05
MAX_TOKENS=512
VERIFIER_MAX_TOKENS=512
MEMORY_PATH=data/conversation.json
ROUTER_STATE_PATH=data/router_state.json
