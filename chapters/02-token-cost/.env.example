# 在 DeepSeek 开放平台创建 API Key 后，替换等号右侧的示例文字。
DEEPSEEK_API_KEY=把你的_API_Key_填在这里

# 本章使用 Flash，并关闭思考模式，让 Token 结构更容易观察。
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=512

# 2026-07-13 DeepSeek 官方页面列出的美元价格。
# 单位均为“每 100 万 Token”。价格可能调整，运行前请再次核对官方页面。
DEEPSEEK_PRICE_CACHE_HIT_USD_PER_M=0.0028
DEEPSEEK_PRICE_CACHE_MISS_USD_PER_M=0.14
DEEPSEEK_PRICE_OUTPUT_USD_PER_M=0.28
